{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "js",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
